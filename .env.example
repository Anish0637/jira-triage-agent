# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-company.com
JIRA_API_TOKEN=your-jira-api-token          # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_DASHBOARD_ID=12042

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Pinecone ──────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=jira-resolved-tickets   # created automatically on first run
PINECONE_CLOUD=aws                          # or gcp / azure
PINECONE_REGION=us-east-1

# ── Email (HITL approval notifications) ───────────────────────────────────────
SMTP_HOST=smtp.office365.com               # or smtp.gmail.com etc.
SMTP_PORT=587
SMTP_USER=you@your-company.com             # account that sends the email
SMTP_PASSWORD=your-app-password            # use an App Password, not your login password
APPROVER_EMAIL=approver@your-company.com
STREAMLIT_URL=http://localhost:8501
